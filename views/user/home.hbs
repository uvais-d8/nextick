    <!-- ✅ Add this inside your <head> -->
	<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
	<!-- GSAP for 3D hover tilt -->
	<script src="https://cdn.jsdelivr.net/npm/gsap@3.14.1/dist/gsap.min.js"></script>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			const banner = document.querySelector('.banner');
			const title = document.querySelector('.banner h1');
			const subtitle = document.querySelector('.banner p');
			const cta = document.querySelector('.cta-button');
			const watches = document.querySelectorAll('.watch');
			const particles = document.querySelector('.particles');

			setTimeout(() => {
				title.style.opacity = '1';
				title.style.transform = 'translateY(0)';
			}, 500);

			setTimeout(() => {
				subtitle.style.opacity = '1';
				subtitle.style.transform = 'translateY(0)';
			}, 1000);

			setTimeout(() => {
				cta.style.opacity = '1';
				cta.style.transform = 'scale(1)';
			}, 1500);

			watches.forEach((watch, index) => {
				setTimeout(() => {
					watch.style.opacity = '1';
					watch.style.transform = 'translateY(0)';
				}, 2000 + index * 300);
			});

			for (let i = 0; i < 50; i++) {
				createParticle();
			}

			function createParticle() {
				const particle = document.createElement('div');
				particle.style.position = 'absolute';
				particle.style.width = '2px';
				particle.style.height = '2px';
				particle.style.background = 'white';
				particle.style.borderRadius = '50%';
				particle.style.opacity = Math.random();
				particle.style.left = Math.random() * 100 + '%';
				particle.style.top = Math.random() * 300 + 'px';
				particles.appendChild(particle);

				animateParticle(particle);
			}

			function animateParticle(particle) {
				let posX = parseFloat(particle.style.left);
				let posY = parseFloat(particle.style.top);
				let speed = Math.random() * 1 + 0.5;

				function update() {
					posY -= speed;
					if (posY < -10) {
						posY = 310;
						posX = Math.random() * 100;
					}
					particle.style.left = posX + '%';
					particle.style.top = posY + 'px';
					requestAnimationFrame(update);
				}

				update();
			}

			watches.forEach(watch => {
				watch.addEventListener('mouseover', () => {
					const name = watch.getAttribute('data-name');
					subtitle.textContent = `Featuring the ${name}`;
					subtitle.style.color = '#4CAF50';
				});

				watch.addEventListener('mouseout', () => {
					subtitle.textContent = 'Discover our revolutionary smartwatches';
					subtitle.style.color = 'white';
				});
			});
		});
	</script>
	<script>
		const targetDate = new Date("2025/10/31 00:00:00").getTime();

		function updateCountdown() {
			const now = new Date().getTime();
			const timeRemaining = targetDate - now;

			const days = Math.floor(timeRemaining / (1000 * 60 * 60 * 20));
			const hours = Math.floor((timeRemaining % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
			const minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));
			const seconds = Math.floor((timeRemaining % (1000 * 60)) / 1000);

			document.getElementById("days").innerText = days;
			document.getElementById("hours").innerText = hours;
			document.getElementById("minutes").innerText = minutes;
			document.getElementById("seconds").innerText = seconds;

			if (timeRemaining < 0) {
				clearInterval(countdownInterval);
				document.getElementById("days").innerText = "00";
				document.getElementById("hours").innerText = "00";
				document.getElementById("minutes").innerText = "00";
				document.getElementById("seconds").innerText = "00";
				alert("Countdown has ended!");
			}
		}

		const countdownInterval = setInterval(updateCountdown, 1000);
	</script>
	<script>
		const productCards = document.querySelectorAll('.single-product-item');

		productCards.forEach(card => {
			card.addEventListener('mousemove', e => {
				const rect = card.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const y = e.clientY - rect.top;
				const cx = rect.width / 2;
				const cy = rect.height / 2;
				const dx = x - cx;
				const dy = y - cy;
				const tiltX = dy / cy * 8; // adjust tilt
				const tiltY = -dx / cx * 8;

				gsap.to(card, {
					rotationX: tiltX,
					rotationY: tiltY,
					transformPerspective: 800,
					transformOrigin: "center",
					duration: 0.3
				});
			});

			card.addEventListener('mouseleave', e => {
				gsap.to(card, { rotationX: 0, rotationY: 0, duration: 0.5 });
			});
		});
	</script>
	<script>
		const boxes = document.querySelectorAll('.list-box');

		boxes.forEach(box => {
			box.addEventListener('mousemove', e => {
				const rect = box.getBoundingClientRect();
				const x = e.clientX - rect.left;
				const y = e.clientY - rect.top;
				const cx = rect.width / 2;
				const cy = rect.height / 2;
				const dx = x - cx;
				const dy = y - cy;
				const tiltX = dy / cy * 10; // tilt angle
				const tiltY = -dx / cx * 10;

				gsap.to(box, {
					rotationX: tiltX,
					rotationY: tiltY,
					transformPerspective: 1000,
					transformOrigin: "center",
					duration: 0.3
				});
			});

			box.addEventListener('mouseleave', e => {
				gsap.to(box, { rotationX: 0, rotationY: 0, duration: 0.5 });
			});
		});
	</script>
	<script>
		document.querySelectorAll('.single-homepage-slider').forEach((section, index) => {
			const subtitle = section.querySelector('.subtitle');
			const title = section.querySelector('h1');
			const buttons = section.querySelectorAll('.hero-btns a');

			gsap.set([subtitle, title, buttons], { opacity: 0, y: 50 });
			const observer = new IntersectionObserver(entries => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						const tl = gsap.timeline({ defaults: { ease: "power4.out", duration: 1 } });
						tl.to(subtitle, { opacity: 1, y: 0 })
							.to(title, { opacity: 1, y: 0, scale: 1.05 }, "-=0.4")
							.to(buttons, { opacity: 1, y: 0, stagger: 0.2 }, "-=0.3");

						observer.unobserve(section); // Run once
					}
				});
			}, { threshold: 0.5 });

			observer.observe(section);
		});

		gsap.to("h1", {
			textShadow: "0px 0px 25px rgba(255,255,255,0.3)",
			repeat: -1,
			yoyo: true,
			duration: 2.5,
			ease: "sine.inOut"
		});
	</script>
