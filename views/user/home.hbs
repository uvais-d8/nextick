<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="description"
		content="Responsive Bootstrap4 Shop Template, Created by Imran Hossain from https://imransdesign.com/">

	<!-- title -->
	<title>NEXTICK</title>
	<!-- favicon -->
	<link rel="shortcut icon" type="image/png" href="/assets/favicons.png">
	<!-- google font -->
	<link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,700" rel="stylesheet">
	<link href="https://fonts.googleapis.com/css?family=Poppins:400,700&display=swap" rel="stylesheet">
	<!-- fontawesome -->
	<link rel="stylesheet" href="/assets/css/all.min.css">
	<!-- bootstrap -->
	<link rel="stylesheet" href="/assets/bootstrap/css/bootstrap.min.css">
	<!-- owl carousel -->
	<link rel="stylesheet" href="/assets/css/owl.carousel.css">
	<!-- magnific popup -->
	<link rel="stylesheet" href="/assets/css/magnific-popup.css">
	<!-- animate css -->
	<link rel="stylesheet" href="/assets/css/animate.css">
	<!-- mean menu css -->
	<link rel="stylesheet" href="/assets/css/meanmenu.min.css">
	<!-- main style -->
	<link rel="stylesheet" href="/assets/css/main.css">
	<!-- responsive -->
	<link rel="stylesheet" href="/assets/css/responsive.css">
	
	<style>
		.list-section {
			perspective: 1500px;
			/* for 3D effect */
			padding: 80px 0;
			background: #f0f0f0;
		}

		.list-box {
			background: #fff;
			border-radius: 20px;
			padding: 30px;
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
			transform-style: preserve-3d;
			transition: transform 0.5s ease, box-shadow 0.5s ease;
			cursor: pointer;
		}

		.list-box:hover {
			box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
		}

		.list-icon {
			font-size: 50px;
			margin-right: 20px;
			color: #4CAF50;
			transform: translateZ(30px);
		}

		.content h3 {
			margin-bottom: 5px;
			transform: translateZ(20px);
		}

		.content p {
			color: #666;
			transform: translateZ(10px);
		}

		/* Optional: float animation for cards */
		.card-float {
			animation: floatAnim 6s ease-in-out infinite;
		}

		@keyframes floatAnim {

			0%,
			100% {
				transform: translateY(0px);
			}

			50% {
				transform: translateY(-15px);
			}
		}

		.hero-text {
			color: white;
			text-shadow: 0 0 20px rgba(255, 255, 255, 0.15);
			transform-style: preserve-3d;
		}

		.hero-text h1 {
			font-size: 3rem;
			font-weight: 800;
			line-height: 1.2;
		}

		.hero-text .subtitle {
			font-size: 1.2rem;
			letter-spacing: 2px;
			color: #ffb347;
			text-transform: uppercase;
		}

		.hero-btns a {
			transition: all 0.4s ease;
		}

		.hero-btns a:hover {
			transform: translateY(-3px);
			box-shadow: 0 5px 20px rgba(255, 255, 255, 0.3);
		}

		/* Background fade for a smooth reveal */
		.single-homepage-slider {
			position: relative;
			overflow: hidden;
			background-size: cover;
			background-position: center;
		} 
		.list-section {
			perspective: 1500px;
			/* for 3D effect */
			padding: 80px 0;
			background: #f0f0f0;
		}

		.list-box {
			background: #fff;
			border-radius: 20px;
			padding: 30px;
			box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
			transform-style: preserve-3d;
			transition: transform 0.5s ease, box-shadow 0.5s ease;
			cursor: pointer;
		}

		.list-box:hover {
			box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
		}

		.list-icon {
			font-size: 50px;
			margin-right: 20px;
			color: #4CAF50;
			transform: translateZ(30px);
		}

		.content h3 {
			margin-bottom: 5px;
			transform: translateZ(20px);
		}

		.content p {
			color: #666;
			transform: translateZ(10px);
		}

		/* Optional: float animation for cards */
		.card-float {
			animation: floatAnim 6s ease-in-out infinite;
		}

		@keyframes floatAnim {

			0%,
			100% {
				transform: translateY(0px);
			}

			50% {
				transform: translateY(-15px);
			}
		}


		/* Center Glassmorphism Box */
		.box {
			width: 85%;
			max-width: 1200px;
			margin: 10%;
			height: 70vh;
			border-radius: 30px;
			overflow: hidden;

			/* Glassmorphism Effects */
			background: rgba(255, 210, 121, 0.553);
			backdrop-filter: blur(25px) saturate(180%);
			-webkit-backdrop-filter: blur(25px) saturate(180%);
			border: 1px solid rgba(255, 255, 255, 0.5);
			box-shadow:
				0 20px 80px rgba(0, 0, 0, 0.15),
				inset 0 0 40px rgba(255, 255, 255, 0.2);

			/* Futuristic Glow Gradient */
			background-image: linear-gradient(135deg,
					rgba(255, 153, 51, 0.25),
					rgba(255, 255, 255, 0.05));
			animation: boxGlow 6s infinite alternate ease-in-out;
		}

		@keyframes boxGlow {
			0% {
				box-shadow: 0 15px 50px rgba(255, 153, 51, 0.1);
			}

			100% {
				box-shadow: 0 15px 80px rgba(255, 153, 51, 0.4);
			}
		}

		/* Wrapper for Content */
		.content-wrapper {
			display: flex;
			justify-content: space-between;
			align-items: center;
			height: 100%;
			width: 100%;
			padding: 60px;
			background: rgba(255, 255, 255, 0.1);
			border-radius: 30px;
			position: relative;
			z-index: 2;
		}

		/* Glow Effects */
		.floating-glow {
			position: absolute;
			width: 400px;
			height: 400px;
			top: 15%;
			left: -12%;
			background: radial-gradient(circle at center, rgba(255, 140, 0, 0.5), transparent 70%);
			filter: blur(120px);
			animation: floatGlow 10s ease-in-out infinite alternate;
			z-index: 1;
		}

		.floating-glow.glow2 {
			top: 60%;
			left: 65%;
			background: radial-gradient(circle at center, rgba(255, 255, 255, 0.4), transparent 70%);
			animation-delay: 5s;
		}

		@keyframes floatGlow {
			0% {
				transform: translateY(0);
				opacity: 0.8;
			}

			100% {
				transform: translateY(40px);
				opacity: 1;
			}
		}

		/* Text Content */
		.text-content {
			flex: 1;
			z-index: 3;
		}

		.text-content h1 {
			color: #000;
			font-size: 3.5rem;
			font-weight: 800;
			margin-bottom: 20px;
			letter-spacing: 1px;
		}

		.text-content h1 span {
			color: #ff8c1a;
			text-shadow: 0 0 20px rgba(255, 140, 0, 0.7);
		}

		.text-content p {
			color: rgba(0, 0, 0, 0.85);
			font-weight: 500;
			font-size: 1.2rem;
			margin-bottom: 40px;
			opacity: 0.9;
		}

		/* CTA Button */
		.cta-button {
			display: inline-block;
			padding: 14px 40px;
			border-radius: 50px;
			background: linear-gradient(135deg, #ff7a00, #ffb84d);
			color: white;
			font-weight: 700;
			font-size: 1.1rem;
			text-decoration: none;
			box-shadow: 0 8px 25px rgba(255, 140, 0, 0.4);
			transition: all 0.4s ease;
		}

		.cta-button:hover {
			background: linear-gradient(135deg, #212b3c, #11043358);
			transform: scale(1.08);
			display: inline-block;
			padding: 14px 40px;
			border-radius: 50px;
			color: rgb(233, 157, 7);
			font-weight: 700;
			font-size: 1.1rem;
			text-decoration: none;
			box-shadow: 0 8px 25px rgba(255, 140, 0, 0.4);
			transition: all 0.6s ease;
		}

		/* Watch 3D Cube */
		.watch-showcase {
			flex: 1;
			display: flex;
			justify-content: center;
			align-items: center;
			perspective: 1400px;
		}

		.watch-3d {
			width: 250px;
			height: 250px;
			position: relative;
			transform-style: preserve-3d;
			animation: rotateCube 12s infinite linear;
		}

		/* Each face of cube */
		.watch-face {
			position: absolute;
			width: 100%;
			height: 100%;
			background-size: cover;
			background-position: center;
			border-radius: 10px;
			box-shadow: 0 0 25px rgba(255, 210, 121, 0.553);
			border: 1px solid rgba(255, 255, 255, 0.3);
			backface-visibility: hidden;
			/* ✅ Important fix */
		}

		/* Adjust cube depth (half of size = 125px for 250px cube) */
		.front {
			transform: translateZ(125px);
		}

		.back {
			transform: rotateY(180deg) translateZ(125px);
		}

		.right {
			transform: rotateY(90deg) translateZ(125px);
		}

		.left {
			transform: rotateY(-90deg) translateZ(125px);
		}

		.top {
			transform: rotateX(90deg) translateZ(125px);
		}

		.bottom {
			transform: rotateX(-90deg) translateZ(125px);
		}

		/* Smooth infinite rotation */
		@keyframes rotateCube {
			0% {
				transform: rotateX(0deg) rotateY(0deg);
			}

			50% {
				transform: rotateX(180deg) rotateY(180deg);
			}

			100% {
				transform: rotateX(360deg) rotateY(360deg);
			}
		}
		.section-title h3 {
			font-size: 36px;
			font-weight: 700;
			color: #333;
			margin-bottom: 10px;
		}

		.section-title .orange-text {
			color: #ff8800;
		}

		.section-title p {
			font-size: 16px;
			color: #555;
		}

		/* Product Card Styles */
		.single-product-item {
			background: rgba(255, 255, 255, 0.15);
			border-radius: 20px;
			padding: 20px;
			margin: 20px 0;
			box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
			backdrop-filter: blur(10px);
			-webkit-backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, 0.3);
			transform-style: preserve-3d;
			transition: transform 0.5s ease, box-shadow 0.5s ease;
			cursor: pointer;
		}

		.single-product-item:hover {
			box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
		}

		/* Image Hover Effect */
		.product-image img {
			border-radius: 15px;
			width: 100%;
			height: 270px;
			object-fit: cover;
			transition: transform 0.5s ease, box-shadow 0.5s ease;
		}

		.single-product-item:hover img {
			transform: scale(1.05) rotate(1deg);
			box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
		}

		/* Product Info */
		.single-product-item h3 {
			margin: 15px 0 10px;
			color: #000000;
			font-size: 22px;
		}

		.price,
		.offer-price,
		.discount-tag {
			display: inline-block;
			margin: 5px 5px 5px 0;
			font-weight: bold;
		}

		.price {
			color: #ff4d4d;
			text-decoration: line-through;
		}

		.offer-price {
			color: #4CAF50;
			font-size: 20px;
		}

		.discount-tag {
			font-size: 13px;
			color: #ff8800;
		}

		/* Add to Cart Button */
		.cart-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			background: #ff8800;
			color: #fff;
			padding: 10px 20px;
			border-radius: 12px;
			margin-top: 10px;
			font-weight: 600;
			transition: all 0.3s ease;
		}

		.cart-btn:hover {
			background: #ff6600;
			transform: scale(1.05);
		}

		/* Floating Animation */
		.card-float {
			animation: floatAnim 5s ease-in-out infinite;
		}

		@keyframes floatAnim {

			0%,
			100% {
				transform: translateY(0px);
			}

			50% {
				transform: translateY(-10px);
			}
		}

		/* Responsive Grid Fix */
		@media(max-width: 992px) {
			.single-product-item {
				margin: 20px auto;
			}
		}
	</style>
	
</head>
<body>
	<!--PreLoader-->
	<div class="loader">
		<div class="loader-inner">
			<div class="circle"></div>
		</div>
	</div>
	<!--PreLoader Ends-->
	<!-- header -->
	<div class="top-header-area" id="sticker">
		<div class="container">
			<div class="row">
				<div class="col-lg-12 col-sm-12 text-center">
					<div class="main-menu-wrap">
						<!-- logo -->
						<div class="site-logo">
							<a href="/">
								<p
									style="font-size:28px; color:white;margin-top:-5px;font-family:'Gill Sans', 'Gill Sans MT', Calibri, 'Trebuchet MS', sans-serif">
									NEXTIC<span style="font-weight: bold;color:rgb(238, 149, 15)">K</span></p>
							</a>
						</div>
						<!-- logo -->

						<!-- menu start -->
						<nav class="main-menu">

							<ul>
								<li class="current-list-item"><a href="/">Home</a>
								</li>
								<li><a href="/about">About</a></li>
								<li><a href="/products">Products</a></li>

								<ul class="sub-menu">
									<li><a href="/news">News</a></li>
									<li><a href="/single-news">Single News</a></li>
								</ul>
								</li>
								<li><a href="/contact">Contact</a></li>

								<ul class="sub-menu">
									<li>
										<form class="a" method="get" action="/shop">Shop</form>
									</li>
									<li><a href="/checkout">Check Out</a></li>
									<li><a href="/single-product">Single Product</a></li>
									<li><a href="/cart">Cart</a></li>
								</ul>
								</li>
								<li>
									{{#if userId}}
									<!-- Show Log Out button if user is logged in -->
									<form method="post" action="/logout">
										<button class="a" type="submit"
											style="color:white; background: none; border: none; cursor: pointer; font-weight: bold">
											Log Out
										</button>
									</form>
									{{else}}
									<!-- Show Log In button if no user is logged in -->
									<a href="/login" style="color:white; font-weight: bold;">Log In</a>
									{{/if}}
								</li>

								<li>
									<div class="header-icons">
										<a href="/wishlist" class="love-icon">
											<i class="fas fa-heart"></i>
										</a>
										<a class="shopping-cart" href="/cart"><i class="fas fa-shopping-cart"></i></a>

										<a class="shopping-cart" href="/profile"><i class="fas fa-user"></i></a>
									</div>
								</li>

							</ul>
						</nav>


						<a class="mobile-show search-bar-icon" href="#"><i class="fas fa-search"></i></a>
						<div class="mobile-menu"></div>


						<!-- menu end -->
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- end header -->
	<!-- search area -->
	<div class="search-area">
		<div class="container">
			<div class="row">
				<div class="col-lg-12">
					<span class="close-btn"><i class="fas fa-window-close"></i></span>
					<div class="search-bar">
						<div class="search-bar-tablecell">
							<h3>Search For:</h3>
							<input type="text" placeholder="Keywords">
							<button type="submit">Search <i class="fas fa-search"></i></button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- end search area -->

	<!-- home page slider -->
	<div class="homepage-slider">
		<!-- single home slider -->
		<div class="single-homepage-slider homepage-bg-1">
			<div class="container">
				<div class="row">
					<div class="col-md-12 col-lg-7 offset-lg-1 offset-xl-0">
						<div class="hero-text">
							<div class="hero-text-tablecell">
								<p class="subtitle">smart & style</p>
								<h1>Smart choices, smarter watches</h1>
								<div class="hero-btns">
									<a href="/products" class="boxed-btn">New Collection</a>
									<a href="/contact" class="bordered-btn">Contact Us</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- single home slider -->
		<div class="single-homepage-slider homepage-bg-2">
			<div class="container">
				<div class="row">
					<div class="col-lg-10 offset-lg-1 text-center">
						<div class="hero-text">
							<div class="hero-text-tablecell">
								<p class="subtitle">Track & connect</p>
								<h1>Wear the future, today</h1>
								<div class="hero-btns">
									<a href="/shop" class="boxed-btn">Visit Shop</a>
									<a href="/contact" class="bordered-btn">Contact Us</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<!-- single home slider -->
		<div class="single-homepage-slider homepage-bg-3">
			<div class="container">
				<div class="row">
					<div class="col-lg-10 offset-lg-1 text-right">
						<div class="hero-text">
							<div class="hero-text-tablecell">
								<p class="subtitle">Mega Sale Going On!</p>
								<h1>Get December Discount</h1>
								<div class="hero-btns">
									<a href="/shop" class="boxed-btn">Visit Shop</a>
									<a href="/contactbs" class="bordered-btn">Contact Us</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- end home page slider -->

	{{!-- <div class="headers-icons">
		<a style="color:rgb(255, 200, 0)" class="search-bar-icon" href="/profile"><i class="fas fa-user"></i></a>
		<a style="color:rgb(255, 200, 0)" href="/wishlist" class="love-icon">
			<i class="fas fa-heart"></i>
		</a>
		<a style="color:rgb(255, 200, 0)" class="shopping-cart" href="/cart"><i class="fas fa-shopping-cart"></i></a>
	</div> --}}
	
	<!-- features list section --> 

	<div class="list-section">
		<div class="container">
			<div class="row">
				<div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
					<div class="list-box card-float">
						<div class="list-icon">
							<i class="fas fa-shipping-fast"></i>
						</div>
						<div class="content">
							<h3>Free Shipping</h3>
							<p>When order over Rs 100</p>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
					<div class="list-box card-float">
						<div class="list-icon">
							<i class="fas fa-phone-volume"></i>
						</div>
						<div class="content">
							<h3>24/7 Support</h3>
							<p>Get support all day</p>
						</div>
					</div>
				</div>
				<div class="col-lg-4 col-md-6">
					<div class="list-box card-float">
						<div class="list-icon">
							<i class="fas fa-sync"></i>
						</div>
						<div class="content">
							<h3>Refund</h3>
							<p>Get refund within 3 days!</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!-- end features list section -->
	<div class="product-section">
		<div class="container">
			<div class="row">
				<div class="col-lg-8 offset-lg-2 text-center">
					<div class="section-title">
						<h3 style="margin-top: 40px;"><span class="orange-text">Our</span> Products</h3>
						<p>Discover cutting-edge smartwatches that blend style, functionality, and innovation—perfect
							for staying connected and elevating your lifestyle</p>
					</div>
				</div>
			</div>

			<div class="row">
				{{#each products}}
				<div class="col-lg-4 col-md-6 text-center">
					<div class="single-product-item card-float">
						<div class="product-image">
							<a href="/product/{{_id}}">
								<img src="/{{this.images.[0]}}" alt="{{this.name}}">
							</a>
						</div>
						<h3>{{this.name}}</h3>
						{{#if this.offerPrice}}
						{{#if (neq this.offerPrice this.price)}}
						<span class="price">₹{{this.price}}</span>
						<span class="offer-price">₹{{this.offerPrice}}</span>
						<span class="discount-tag">
							({{this.discountValue}}{{#if (eq this.discountType "percentage")}} OFF{{else}} ₹ OFF{{/if}})
						</span>
						{{else}}
						<span class="offer-price">₹{{this.price}}</span>
						{{/if}}
						{{else}}
						<span class="offer-price">₹{{this.price}}</span>
						{{/if}}
						<form action="/addtocart" style="margin-left: -20px;" method="post">
							<input type="hidden" name="productId" value="{{this._id}}">
							<input type="hidden" name="quantity" value="1">
							<div style="margin-left:30%">
								<button
									style="background-color: transparent;border: none;padding: 0;margin: 0;cursor: pointer;display: flex;align-items: center;font: inherit;color: inherit;outline:none "
									type="submit" class="cart-btn">
									<a class="cart-btn"><i style="margin-right: 10px;" class="fas fa-shopping-cart"></i>
										Add to Cart</a>
								</button>
							</div>

						</form>
					</div>
				</div>
				{{/each}}
			</div>
		</div>
